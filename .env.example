# Environment template — copy to .env and fill in values
# Used by cast-manager and referenced by other services

SSH_HOST=<server-ip>
SSH_USER=<username>
SSH_PASSWORD=<password>
TRANSMISSION_USER=transmission
TRANSMISSION_PASS=transmission
DOWNLOAD_DIR=/home/<username>/watch_list
CHROMECAST_NAME=REDACTED_DEVICE
CATT_PATH=/home/<username>/.local/bin/catt
PORT=8004
NODE_ENV=production
PUBLIC_URL=
STREAM_TOKEN_EXPIRY_HOURS=24
TRANSCODE_CACHE_DIR=/tmp/cast_manager_cache
TRASH_DIR=/home/<username>/.cast_manager/trash
